# ------------------------------------------------------------
# Docker backend: required
# ------------------------------------------------------------
DB_URL=postgresql+psycopg://admin:admin@db:5432/flowspace
SECRET_KEY=replace_with_a_long_random_secret

# ------------------------------------------------------------
# Docker backend: runtime
# ------------------------------------------------------------
# In Docker we want schema auto-apply on startup.
RUN_MIGRATIONS=true
# In Docker backend must bind to all container interfaces.
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Add every frontend origin that will call the API.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ------------------------------------------------------------
# Docker file storage inside container
# ------------------------------------------------------------
FILES_DIR=/data/files

# ------------------------------------------------------------
# Optional OAuth (uncomment only if you use it)
# ------------------------------------------------------------
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ------------------------------------------------------------
# Password reset via email (uncomment and fill to enable)
# ------------------------------------------------------------
# FRONTEND_URL=https://flowspace.adanteeed.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_FROM=your@gmail.com

# ------------------------------------------------------------
# Frontend runtime (Vite)
# ------------------------------------------------------------
# With reverse proxy, route API via the same origin path.
VITE_API_BASE_URL=/api
# ------------------------------------------------------------
# Frontend API base URL
# ------------------------------------------------------------
# Optional. Defaults to /api (proxied through Vite dev server or reverse proxy).
# Override only if backend is accessed directly (e.g. VITE_API_BASE_URL=http://localhost:8000).
VITE_API_BASE_URL=

# ------------------------------------------------------------
# Frontend admin UI access (emails)
# ------------------------------------------------------------
VITE_ADMIN_EMAILS=admin@example.com
